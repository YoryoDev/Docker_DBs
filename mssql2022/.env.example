# IP de la interfaz del servidor/VM a la que se expone el puerto del contenedor.
# 127.0.0.1 → solo acceso local (recomendado por defecto).
# Cambia a la IP de tu servidor (p. ej. 192.168.1.10) para acceso remoto en tu red.
# Usa 0.0.0.0 solo si necesitas escuchar en TODAS las interfaces (no recomendado).
BIND_ADDRESS=127.0.0.1

MSSQL_SA_PASSWORD=YourStrong@Password1
