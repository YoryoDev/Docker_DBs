# =============================================================
# MariaDB 11.4 LTS — Configuración del servidor
# Baseline: 1 GB de RAM — escala los valores de memoria según
# los recursos reales de tu servidor/VM/nube.
# =============================================================

[mysqld]

# ── Red ───────────────────────────────────────────────────────
bind-address                  = 0.0.0.0
port                          = 3306

# ── Character Set & Collation ─────────────────────────────────
character-set-server          = utf8mb4
collation-server              = utf8mb4_unicode_ci
character_set_filesystem      = utf8mb4

# ── Motor de almacenamiento ───────────────────────────────────
default-storage-engine        = InnoDB

# ── InnoDB ────────────────────────────────────────────────────
innodb_buffer_pool_size       = 256M        # ~25 % de la RAM
innodb_buffer_pool_instances  = 1
innodb_log_file_size          = 64M
innodb_flush_log_at_trx_commit = 1          # 1=ACID completo / 0 o 2=mayor perf.
innodb_flush_method           = O_DIRECT
innodb_file_per_table         = ON
innodb_stats_on_metadata      = OFF
innodb_read_io_threads        = 4
innodb_write_io_threads       = 4

# ── Aria (motor MariaDB para tablas temporales) ───────────────
aria_pagecache_buffer_size    = 128M

# ── Conexiones ────────────────────────────────────────────────
max_connections               = 200
max_connect_errors            = 10000
wait_timeout                  = 600
interactive_timeout           = 600
connect_timeout               = 30
max_allowed_packet            = 64M
thread_cache_size             = 32

# ── Buffers de consulta ───────────────────────────────────────
sort_buffer_size              = 2M
read_buffer_size              = 1M
read_rnd_buffer_size          = 4M
join_buffer_size              = 2M
tmp_table_size                = 64M
max_heap_table_size           = 64M

# ── Binary Log (replicación / recuperación point-in-time) ────
log_bin                       = /var/log/mysql/mariadb-bin
binlog_format                 = ROW
expire_logs_days              = 7
sync_binlog                   = 1
server-id                     = 2

# ── Slow Query Log ────────────────────────────────────────────
slow_query_log                = ON
slow_query_log_file           = /var/log/mysql/mariadb-slow.log
long_query_time               = 2
log_queries_not_using_indexes = ON

# ── Error Log ─────────────────────────────────────────────────
log_error                     = /var/log/mysql/error.log

# ── General Log (desactivar en producción) ────────────────────
general_log                   = OFF
general_log_file              = /var/log/mysql/general.log

# ── SQL Mode ──────────────────────────────────────────────────
sql_mode                      = STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION

# ── SSL/TLS (activar en producción con certificados reales) ───
# ssl-ca                      = /etc/mysql/certs/ca-cert.pem
# ssl-cert                    = /etc/mysql/certs/server-cert.pem
# ssl-key                     = /etc/mysql/certs/server-key.pem


[client]
default-character-set         = utf8mb4
port                          = 3306

[mysql]
default-character-set         = utf8mb4
