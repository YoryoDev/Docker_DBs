# IP de la interfaz del servidor/VM a la que se expone el puerto del contenedor.
# 127.0.0.1 → solo acceso local (recomendado por defecto).
# Cambia a la IP de tu servidor (p. ej. 192.168.1.10) para acceso remoto en tu red.
# Usa 0.0.0.0 solo si necesitas escuchar en TODAS las interfaces (no recomendado).
BIND_ADDRESS=127.0.0.1

# ─── Oracle Container Registry — credenciales de login ──────────────
# El login se ejecuta automáticamente al hacer:
#   docker compose --profile oracle19c up -d
#
# Pasos previos (solo la primera vez):
#   1. Crea cuenta en https://container-registry.oracle.com
#   2. Navega a Database → enterprise y acepta la licencia OTN.
#   3. En el portal ve a tu perfil → "Auth Token" → genera una secret key.
#      Usa esa secret key como contraseña (NO la de tu cuenta SSO).
#      Si contiene '#', enciérrala en comillas dobles.
ORACLE_REGISTRY_USER=tu-correo@ejemplo.com
ORACLE_REGISTRY_PASS="tu-secret-key-aqui"

# ─── Oracle Database 19c Enterprise Edition ───────────────────────────
ORACLE_SID=ORCLCDB
ORACLE_PDB=ORCLPDB1
ORACLE_PWD=YourStrong@Password1
ORACLE_CHARACTERSET=AL32UTF8

# Memoria — ajustado para entorno de lab (~3.8 GB compartidos).
# SGA + PGA = 768 + 256 = 1024 MB para el engine; el container tiene límite 2 GB.
INIT_SGA_SIZE=768
INIT_PGA_SIZE=256

# Habilitar modo ARCHIVELOG (para practicar RMAN / PITR).
# Consume más espacio en disco. Default: false.
# ENABLE_ARCHIVELOG=true
